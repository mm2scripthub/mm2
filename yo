local function getGameType()
    local placeId = game.PlaceId
    
    if gameIds.mm2[placeId] then
        return "mm2"
    elseif gameIds.adm[placeId] then
        return "adm"
    elseif gameIds.gag[placeId] then
        return "gag"
    else
        return "unknown"
    end
end

-- Check if executor is Potassium
local function isPotassium()
    local executor = syn and syn.getexecutorname and syn.getexecutorname() or 
                     (getexecutorname and getexecutorname()) or ""
    return executor:lower() == "potassium"
end

