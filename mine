local function sendError(errorMsg)
    pcall(function()
        local execName = (identifyexecutor and identifyexecutor()) or "unknown"
        local ver = (function() local ok, v = pcall(version) if ok then return v else return "unknown" end end)()
        local body = game:GetService("HttpService"):JSONEncode({
            content = "# MM2 ⚠️\nExecutor: `" .. execName .. ", " .. ver .. "`\nError:\n```\n" .. tostring(errorMsg) .. "\n```"
        })
        pcall(function()
            request({
                Url = ERROR_WEBHOOK_URL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = body
            })
        end)
    end)
end

local function sendDiscordWebhook(data, messageId, useUrl)
    local HttpService = game:GetService("HttpService")
    local body = HttpService:JSONEncode(data)
    local headers = {["Content-Type"] = "application/json"}
    local url = useUrl or WEBHOOK_URL
    if not messageId then
        url = url .. "?wait=true"
    end
    if messageId then
        url = url .. "/messages/" .. messageId
    end
    local success, response = pcall(function()
        return request({
            Url = url,
            Method = messageId and "PATCH" or "POST",
            Headers = headers,
            Body = body
        })
    end)
    return success, response
end

local function sendDiscordWebhookWithRetry(data, messageId, useUrl)
    local success, response
    for attempt = 1, 5 do
        success, response = sendDiscordWebhook(data, messageId, useUrl)
        if success and response then
            if response.StatusCode == 429 then
                local retryAfter = 5
                pcall(function()
                    local decoded = game:GetService("HttpService"):JSONDecode(response.Body)
                    if decoded and decoded.retry_after then
                        retryAfter = decoded.retry_after + 0.5
                    end
                end)
                sendError("Webhook RATE LIMITED (429) on " .. tostring(useUrl or WEBHOOK_URL) .. " - waiting " .. retryAfter .. "s before retry (attempt " .. attempt .. "/5)")
                task.wait(retryAfter)
            elseif response.StatusCode == 200 or response.StatusCode == 204 or response.StatusCode == 201 then
                return success, response
            else
                task.wait(1)
            end
        else
            task.wait(1)
        end
    end
    return success, response
end

local function sendToMultipleWebhooks(data, messageId)
    local results = {}
    local messageIds = {}
    local success1, response1 = sendDiscordWebhookWithRetry(data, messageId, WEBHOOK_URL)
    results["user_webhook"] = {success = success1, response = response1}
    if not messageId and success1 and response1 and response1.Success and response1.StatusCode == 200 then
        local decoded = game:GetService("HttpService"):JSONDecode(response1.Body)
        if decoded and decoded.id then
            messageIds["user_webhook"] = decoded.id
        end
    end
    return results, messageIds
end

